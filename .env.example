# ===== 应用配置 =====
# 日志级别：debug, info, warning, error
LOG_LEVEL=info

# 环境标识：development, staging, production
ENVIRONMENT=production

# ===== Docker 配置 =====
DOCKER_USERNAME=docker
DOCKER_PASSWORD=test!

# ===== 服务器配置（CI/CD 密钥） =====
# GitHub Actions 需要的服务器连接信息
SERVER_USER=deploy
SERVER_HOST=123
SERVER_PORT=22

# 服务器 SSH 私钥（用于 GitHub Actions 连接）
# 生成方式：ssh-keygen -t rsa -f ~/.ssh/id_rsa -N ""
SERVER_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----
...private key content here...
-----END RSA PRIVATE KEY-----

# ===== 应用运行配置 =====
# FastAPI 应用主机和端口（云托管会自动注入 PORT）
API_HOST=0.0.0.0
PORT=8000
ROOT_PATH=
UVICORN_WORKERS=2

# 输出目录（PDF/ZIP 文件保存位置）
OUTPUT_DIR=/app/output

# ===== Nginx 配置 =====
# 服务器域名
SERVER_DOMAIN=mortgage.example.com

# SSL 证书路径（Docker 内部路径）
SSL_CERT_PATH=/etc/nginx/ssl/cert.pem
SSL_KEY_PATH=/etc/nginx/ssl/key.pem

# ===== 可选：数据库配置（预留） =====
# DATABASE_URL=postgresql://user:password@db:5432/mortgage

# ===== 可选：第三方服务配置 =====
# 如果接入 LangChain AI 服务
# OPENAI_API_KEY=sk-...
# LANGCHAIN_API_KEY=...

# ===== 微信小程序云托管 / 腾讯云 TCB =====
TCB_ENV_ID=your-env-id
TCB_REGION=ap-shanghai
TCB_SECRET_ID=your-secret-id
TCB_SECRET_KEY=your-secret-key

# 腾讯云容器镜像服务（TCR）
TCR_SERVER=ccr.ccs.tencentyun.com
TCR_NAMESPACE=mortgage
TCR_USERNAME=tcr-username
TCR_PASSWORD=tcr-password

# 微信小程序配置（如需调用微信侧接口）
WX_APPID=wx-xxxx
WX_APP_SECRET=your-app-secret

# ===== 监控和告警（预留） =====
# SENTRY_DSN=https://...
# PROMETHEUS_ENABLED=false
